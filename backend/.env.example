# ============================================
# BeCool Market - .env 配置模板
# ============================================
# 复制此文件为 .env 并填写你的远程 MySQL 信息
#
# DATABASE_URL=mysql+pymysql://用户名:密码@主机:端口/数据库名
# 示例: mysql+pymysql://root:123456@1.2.3.4:3306/eshshop

DATABASE_URL=mysql+pymysql://root:your_password@your-server-ip:3306/eshshop
SECRET_KEY=becool-market-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
